---
layout: layouts/base.njk
bodyClass: home-page
---

<h1 class="page-heading">Portfolio</h1>

<div class="filter-bar">
  <button class="filter-btn active" data-filter="all">All Work</button>
  <button class="filter-btn" data-filter="art-direction">Art Direction</button>
  <button class="filter-btn" data-filter="banner">Banner</button>
  <button class="filter-btn" data-filter="digital">Digital</button>
  <button class="filter-btn" data-filter="illustration">Illustration</button>
  <button class="filter-btn" data-filter="motion">Motion</button>
  <button class="filter-btn" data-filter="ooh">OOH</button>
  <button class="filter-btn" data-filter="print">Print</button>
  <button class="filter-btn" data-filter="promotional">Promotional</button>
  <button class="filter-btn" data-filter="social">Social</button>
  <button class="filter-btn" data-filter="ux-ui">UX/UI</button>
</div>

<div class="filter-bar-mobile">
  <div class="custom-select" id="customSelect">
    <button class="custom-select-trigger" aria-haspopup="listbox" aria-expanded="false">
      <span class="custom-select-label">All Work</span>
      <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1l5 5 5-5" stroke="#0f0f0f" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
    <ul class="custom-select-list" role="listbox">
      <li class="custom-select-option active" data-value="all" role="option">All Work</li>
      <li class="custom-select-option" data-value="art-direction" role="option">Art Direction</li>
      <li class="custom-select-option" data-value="banner" role="option">Banner</li>
      <li class="custom-select-option" data-value="digital" role="option">Digital</li>
      <li class="custom-select-option" data-value="illustration" role="option">Illustration</li>
      <li class="custom-select-option" data-value="motion" role="option">Motion</li>
      <li class="custom-select-option" data-value="ooh" role="option">OOH</li>
      <li class="custom-select-option" data-value="print" role="option">Print</li>
      <li class="custom-select-option" data-value="promotional" role="option">Promotional</li>
      <li class="custom-select-option" data-value="social" role="option">Social</li>
      <li class="custom-select-option" data-value="ux-ui" role="option">UX/UI</li>
    </ul>
  </div>
</div>

<div class="portfolio-grid">
  {% for p in projects %}
  {% if not p.exploration and not p.hidden %}
  <a href="/work/{{ p.slug }}/" class="portfolio-item" data-categories="{{ p.categories | catClasses }}">
    {% if p.cover %}
    <img src="/uploads/{{ p.cover }}" alt="{{ p.title }}" loading="{% if loop.index <= 8 %}eager{% else %}lazy{% endif %}">
    {% endif %}
    <div class="portfolio-item-overlay">
      <h3 class="portfolio-item-title">{{ p.title }}</h3>
      <p class="portfolio-item-cats">{{ p.categories | join(" / ") }}</p>
    </div>
  </a>
  {% endif %}
  {% endfor %}
</div>
